{
  "name": "chuno",
  "version": "0.0.1",
  "private": true,
  "description": "추노(Chuno) - 러닝 경주 매칭 서비스 모노레포",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "api:dev": "pnpm --filter core-api start:dev",
    "api:build": "pnpm --filter core-api build",
    "api:start": "pnpm --filter core-api start:prod",
    "app:run": "cd apps/chuno-mobile && flutter run",
    "app:watch": "bash apps/chuno-mobile/tools/watch_run.sh"
  }
}
