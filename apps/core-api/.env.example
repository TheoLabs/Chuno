# MySQL (로컬 도커: root / 1234, DB chuno, 3306)
MYSQL_HOST=localhost
MYSQL_USERNAME=root
MYSQL_PASSWORD=1234
MYSQL_DATABASE=chuno

# Google OAuth (모바일 클라이언트 ID)
GOOGLE_MOBILE_CLIENT_ID=

# Apple Sign in (클라이언트 ID / bundle ID = idToken aud)
APPLE_CLIENT_ID=

# 소셜 검증 dev 모드 — "dev:<sub>:<email>" 토큰으로 실키 없이 로컬 로그인. 로컬 전용, 프로덕션 false.
AUTH_DEV_MODE=true

# JWT (미설정 시 코드 기본값 사용). 액세스 기본 15m(스펙), 리프레시 회전 만료 기본 30일.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30
